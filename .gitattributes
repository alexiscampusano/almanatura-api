# Default: normalize all text files to LF in the repository,
# convert to native on checkout (Windows gets CRLF, Linux/macOS get LF).
* text=auto eol=lf

# Sources & configs — always LF, regardless of OS
*.java          text eol=lf
*.kt            text eol=lf
*.xml           text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.properties    text eol=lf
*.sql           text eol=lf
*.md            text eol=lf
*.json          text eol=lf
*.sh            text eol=lf

# Windows scripts — must keep CRLF for cmd.exe
*.cmd           text eol=crlf
*.bat           text eol=crlf

# Maven wrapper — explicit, just in case
mvnw            text eol=lf
mvnw.cmd        text eol=crlf

# Docker
Dockerfile*     text eol=lf
*.dockerfile    text eol=lf
.dockerignore   text eol=lf

# Binaries — never touch
*.jar           binary
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.pdf           binary