# =================================================================
# AlmaNatura API - PRODUCTION environment template
# -----------------------------------------------------------------
# This file is the template you copy on the production server:
#   cp .env.production.example .env
#   chmod 600 .env
#   # then fill in REAL values (never commit them).
#
# NEVER commit the real .env. Only this template is in git.
# Rotate every secret on every environment promotion.
# =================================================================

# Active Spring profile inside the container is forced to "docker" by
# docker-compose.prod.yml; in production we additionally activate "prod"
# (no Swagger, no Actuator details, no DevTools). Do NOT change unless
# you know what you are doing.
SPRING_PROFILES_ACTIVE=docker,prod

# ---- MySQL ----
# Use a database created exclusively for this app, never reuse a shared one.
MYSQL_DATABASE=almanatura
MYSQL_USER=almanatura
# Generate strong DB passwords:
#   openssl rand -base64 24
MYSQL_PASSWORD=CHANGE_ME_DB_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
# In production we DO NOT publish MySQL on the host (see docker-compose.prod.yml).
# This variable is kept for parity with dev tooling but ignored by the prod compose.
MYSQL_PORT=3306

# ---- API ----
# Public port the reverse proxy (nginx / Apache / Cloudflare) forwards to.
API_PORT=8080

# ---- Security: JWT ----
# HS512 requires a secret of >= 64 bytes (512 bits). Generate with:
#   openssl rand -base64 96
APP_JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_VALUE_OF_AT_LEAST_64_BYTES_FOR_HS512_SIGNATURE
# Token lifetime in milliseconds. 1 day = 86400000.
APP_JWT_EXPIRATION_MS=86400000
APP_JWT_ISSUER=almanatura-api

# ---- Security: DNI encryption (AES-256-GCM) ----
# Must decode (base64) to exactly 32 bytes. Generate with:
#   openssl rand -base64 32
# WARNING: data encrypted with a previous key cannot be read by a new one.
# Rotating this value requires a documented re-encryption migration.
APP_ENCRYPTION_DNI_KEY=CHANGE_ME_BASE64_32_BYTES

# ---- CORS ----
# Comma-separated list of frontend origins allowed to call the API.
# In production this should ONLY contain the public site, never localhost.
APP_CORS_ALLOWED_ORIGINS=https://app.almanatura.org

# ---- Initial Super User ----
# Created on first startup if no user with this email exists.
# After bootstrap you can either:
#   - leave it (idempotent: already-existing email is skipped), or
#   - set both to empty to disable the bootstrap entirely.
# Must be 12-100 chars: lower + upper + digit + one of !@#$%^&*()_+-=[]{}|;:,.?
# The app will refuse to start if this password is set but does not comply.
APP_ADMIN_EMAIL=admin@almanatura.org
APP_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD_MEETING_POLICY

# ---- Rate limiting (in-memory buckets per client IP) ----
# Tighter limits in production to mitigate brute-force / abuse.
APP_RATELIMIT_LOGIN_REQUESTS=5
APP_RATELIMIT_LOGIN_WINDOW_MINUTES=1
APP_RATELIMIT_REGISTER_REQUESTS=10
APP_RATELIMIT_REGISTER_WINDOW_MINUTES=1
