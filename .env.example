# =================================================================
# AlmaNatura API - Environment configuration
# -----------------------------------------------------------------
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# NEVER commit .env to version control.
# =================================================================

# Active Spring profile for LOCAL runs (./mvnw spring-boot:run).
# - "dev"  -> connects to localhost:3306 (MySQL must run via Docker:
#             `docker compose up -d almanatura-db`). Hot reload + verbose logs.
# - "prod" -> production-like settings (no DevTools, info logs).
# The Docker container always uses the "docker" profile (forced in
# docker-compose.yml), so this variable does NOT need to change to switch
# between local and containerized runs.
SPRING_PROFILES_ACTIVE=dev

# ---- MySQL ----
MYSQL_DATABASE=almanatura
MYSQL_USER=almanatura
MYSQL_PASSWORD=CHANGE_ME_DB_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_PORT=3306

# ---- API ----
API_PORT=8080

# ---- Security: JWT ----
# HS512 requires a secret of >= 64 bytes (512 bits). Generate with:
#   openssl rand -base64 96
APP_JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_VALUE_OF_AT_LEAST_64_BYTES_FOR_HS512_SIGNATURE
APP_JWT_EXPIRATION_MS=86400000
APP_JWT_ISSUER=almanatura-api

# ---- Security: DNI encryption (AES-256-GCM) ----
# Must decode (base64) to exactly 32 bytes. Generate with:
#   openssl rand -base64 32
APP_ENCRYPTION_DNI_KEY=CHANGE_ME_BASE64_32_BYTES

# ---- CORS ----
# Comma-separated list of frontend origins allowed to call the API.
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- Initial Super User ----
# Created on first startup if no user with this email exists.
# Leave both empty to skip the bootstrap (e.g. on shared environments).
# APP_ADMIN_PASSWORD must meet the same rules as POST /auth/login: 12-100 chars,
# ASCII only, at least one lower, one upper, one digit, one special from:
# !@#$%^&*()_+-=[]{}|;:,.?
# Example (dev only — pick your own): LocalDevAdmin9!
APP_ADMIN_EMAIL=admin@almanatura.org
APP_ADMIN_PASSWORD=LocalDevAdmin9!

# ---- Rate limiting (in-memory buckets per client IP) ----
# Override these to make the limits stricter or looser per environment.
APP_RATELIMIT_LOGIN_REQUESTS=5
APP_RATELIMIT_LOGIN_WINDOW_MINUTES=1
APP_RATELIMIT_REGISTER_REQUESTS=10
APP_RATELIMIT_REGISTER_WINDOW_MINUTES=1
# Set true only behind a trusted reverse proxy that controls X-Forwarded-For (see README).
APP_RATELIMIT_TRUST_FORWARDED_HEADERS=false

# ---- Optional: phpMyAdmin (only when running --profile tools) ----
PHPMYADMIN_PORT=8081

# ---- Mailer (SMTP) ----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=comunicaciones@almanatura.com
MAIL_FROM_NAME=AlmaNatura